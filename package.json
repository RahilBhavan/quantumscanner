    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitejs/plugin-react-oxc": "^0.4.3",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.2",
    "msw": "^2.14.3",
    "prettier": "^3.8.3",
